---
import Wordmark from './Wordmark.astro';
import { REPO_URL, DOWNLOAD_URL, withBase } from '../consts';

const home = withBase();
---

<header class="site-header">
  <div class="wrap header-inner">
    <Wordmark />
    <nav class="site-nav" aria-label="Primary">
      <a href={`${home}#features`}>Features</a>
      <a href={`${home}#how`}>How it works</a>
      <a href={withBase('docs')}>Docs</a>
      <a href={REPO_URL}>GitHub</a>
      <a class="btn primary" href={DOWNLOAD_URL}>Download</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: oklch(0.972 0.004 80 / 0.82);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .site-nav a:not(.btn) {
    color: var(--ink-2);
    font-size: 14.5px;
    font-weight: 500;
  }
  .site-nav a:not(.btn):hover {
    color: var(--ink);
    text-decoration: none;
  }
  .site-nav .btn {
    height: 38px;
    padding: 0 16px;
    font-size: 14px;
  }
  @media (max-width: 880px) {
    .site-nav {
      gap: 16px;
    }
  }
  @media (max-width: 560px) {
    .site-nav a:not(.btn) {
      display: none;
    }
  }
</style>
