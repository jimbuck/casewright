{
  "name": "@casewright/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Casewright desktop app — a craftsman's editor for manual test cases (NW.js + React + TypeScript).",
  "license": "MIT",
  "author": "Jim Buck",
  "main": "dist/index.html",
  "window": {
    "title": "Casewright",
    "width": 1480,
    "height": 940,
    "min_width": 1024,
    "min_height": 640,
    "frame": true,
    "show": true
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "start": "nw ."
  },
  "dependencies": {
    "@casewright/brand": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "nw": "0.112.0-sdk",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
