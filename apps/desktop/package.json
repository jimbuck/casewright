{
  "name": "@casewright/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Casewright desktop app — a craftsman's editor for manual test cases (NW.js + React + TypeScript).",
  "license": "MIT",
  "author": "Jim Buck",
  "main": "dist/index.html",
  "window": {
    "title": "Casewright",
    "width": 1480,
    "height": 940,
    "min_width": 1024,
    "min_height": 640,
    "frame": false,
    "resizable": true,
    "show": true
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "start": "nw ."
  },
  "dependencies": {
    "@casewright/brand": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "nw": "0.112.0-sdk",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
