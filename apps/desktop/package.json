{
  "name": "@casewright/desktop",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Casewright desktop app — a bespoke editor for manual test cases (NW.js + React + TypeScript).",
  "license": "MIT",
  "author": "Jim Buck",
  "main": "dist/index.html",
  "window": {
    "title": "Casewright",
    "icon": "build-resources/icon.png",
    "width": 1480,
    "height": 940,
    "min_width": 1024,
    "min_height": 640,
    "frame": false,
    "resizable": true,
    "show": true
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "fixture": "vite-node scripts/make-fixture.mts",
    "make-icon": "node scripts/make-icon.mjs",
    "package:win": "vite build && node scripts/package-win.mjs",
    "start": "nw ."
  },
  "dependencies": {
    "@casewright/brand": "workspace:*",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.11",
    "papaparse": "^5.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "nw": "0.112.0-sdk",
    "nw-builder": "^4.17.11",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
